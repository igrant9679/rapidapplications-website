# =============================================================================
# CommunityForce CMS — Environment Variables
# =============================================================================
# Copy this file to `.env` for local dev, or set these in Railway's
# "Variables" tab for deployment. NEVER commit a real `.env` (it is gitignored).
#
# NOTE: Variables prefixed with VITE_ are baked into the FRONTEND bundle at
# BUILD TIME. They must be present when Railway runs `pnpm run build`, not just
# at runtime.
# =============================================================================

# --- Core (required for the app to boot) -------------------------------------

# MySQL/TiDB connection string. Use a freshly-rotated credential — do NOT reuse
# the one that was in .project-config.json.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE?ssl={"rejectUnauthorized":true}
DATABASE_URL=

# Secret used to sign session JWT cookies. Generate a new random 64+ char value,
# e.g.  openssl rand -hex 48
JWT_SECRET=

# Railway sets this automatically; the server falls back to 3000 locally.
# Do NOT hardcode this on Railway.
# PORT=3000

# Set by the start script; Railway build/runtime should have it as production.
NODE_ENV=production

# --- Manus OAuth (required for ADMIN LOGIN) ----------------------------------
# The admin dashboard authenticates through Manus's OAuth service. Without these,
# the public site/blog still work but no one can sign in to /admin/*.
# These must point at a Manus OAuth server that is reachable from Railway AND
# has your deployed domain registered as an allowed redirect URI.

VITE_APP_ID=
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=

# The Manus openId that should be auto-promoted to `admin` on first sign-in.
OWNER_OPEN_ID=

# --- Manus "Forge" backend (media uploads, AI, notifications) ----------------
# Powers file/media storage, LLM chat, image generation, maps, voice
# transcription, and notification sending. If these are unset or unreachable,
# those specific features fail gracefully but the rest of the site runs.

BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_KEY=
